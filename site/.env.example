# =============================================================================
# Malerfirmaet Bach ApS – environment variables
# Copy to .env.local and fill in. Never commit .env.local to git.
# =============================================================================

# --- Cloudflare Turnstile (form spam protection)
# Created at: https://dash.cloudflare.com/?to=/:account/turnstile
# Add the site domain (malerfirmaetbach.dk + localhost for dev) → copy both keys
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Calendly (booking)
# Found at: https://calendly.com/event_types — copy the event-URL
NEXT_PUBLIC_CALENDLY_URL=

# --- Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@malerfirmaetbach.dk
LEAD_NOTIFY_EMAIL=info@malerfirmaetbach.dk

# --- Retell AI (Sofia)
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=

# --- Make.com webhooks (forward leads to Airtable etc.)
MAKE_CONTACT_WEBHOOK_URL=
MAKE_SOFIA_WEBHOOK_URL=

# --- Google Analytics 4 (only loaded after cookie-consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Notion CMS (to be activated when architecture decided)
NOTION_TOKEN=
NOTION_SITE_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=

# --- Airtable
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Leads

# --- Google Drive (Service Account for booking-upload + lead folders)
# Setup steps:
#   1. Create a Service Account in Google Cloud Console
#   2. Enable the Google Drive API for the project
#   3. Generate a JSON key, copy the email (xxx@xxx.iam.gserviceaccount.com)
#   4. Paste the entire PRIVATE KEY block as one line — replace newlines with \n
#   5. In Google Drive create a folder "Malerfirmaet Bach — Leads",
#      right-click → Share → paste the service account email with Editor role
#   6. Copy the folder id from its URL → set GOOGLE_DRIVE_FOLDER_ID
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
