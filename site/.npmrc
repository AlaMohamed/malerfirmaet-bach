; React 19 is new enough that several packages haven't updated their
; peer-dependency ranges to declare React 19 compatibility, even though
; they work fine. legacy-peer-deps tells npm to install anyway instead
; of failing — equivalent to passing --legacy-peer-deps on every install.
;
; This matches the behaviour Vercel needs during deploy builds where
; CLI flags aren't passed by default.
legacy-peer-deps=true
